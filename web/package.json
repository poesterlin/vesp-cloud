{
  "name": "esphome-designer",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run --filter @esphome-designer/editor dev",
    "worker": "bun run --filter @esphome-designer/editor worker",
    "dev:admin": "bun run --filter @esphome-designer/admin dev",
    "build": "bun run generate:types && bun run --filter @esphome-designer/editor build",
    "build:admin": "bun run --filter @esphome-designer/admin build",
    "generate:types": "bun run --filter @esphome-designer/schema generate",
    "preview": "bun run --filter @esphome-designer/editor preview",
    "check": "bun run --filter @esphome-designer/editor check",
    "lint": "bun run --filter '*' lint",
    "test": "bun run --filter @esphome-designer/editor test",
    "test:watch": "bun run --filter @esphome-designer/editor test:watch",
    "test:codegen": "bun run --filter @esphome-designer/editor test:codegen",
    "db:generate": "cd packages/editor && bun run db:generate",
    "db:push": "cd packages/editor && bun run db:push"
  },
  "devDependencies": {
    "@mdi/js": "7.4.47",
    "@types/bun": "latest",
    "typescript": "5.9.3",
    "vite-plugin-devtools-json": "1.0.0"
  },
  "module": "index.ts",
  "type": "module"
}
