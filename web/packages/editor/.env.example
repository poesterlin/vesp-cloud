# PostgreSQL Database Connection
DATABASE_URL=postgresql://esphome:changeme@localhost:5432/esphome

# Worker Configuration
CONCURRENT_JOBS=2

# App Edition: "local" | "self-hosted" | "cloud"
# Only "cloud" mode enforces credit checks for paid features
APP_EDITION=local

# Stripe (only required when APP_EDITION=cloud)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Resend (optional until you want to send email)
RESEND_API_KEY=
RESEND_FROM_EMAIL=onboarding@your-domain.com

# Optional: notify this address when a withdrawal is confirmed
WITHDRAWAL_NOTIFY_EMAIL=

# Optional: secret for signing withdrawal step tokens (falls back to STRIPE_WEBHOOK_SECRET)
WITHDRAWAL_TOKEN_SECRET=

# Node Environment
NODE_ENV=development
ESPHOME_USE_PIP=1

# Sentry (optional - leave empty to disable)
SENTRY_DSN=

# Analytics script injected into app.html
PUBLIC_ANALYTICS_SCRIPT_URL=
PUBLIC_ANALYTICS_WEBSITE_ID=

# Public legal-page configuration (required for a public hosted deployment)
PUBLIC_LEGAL_OPERATOR_NAME=
PUBLIC_LEGAL_STREET_ADDRESS=
PUBLIC_LEGAL_POSTAL_CODE=
PUBLIC_LEGAL_LOCALITY=
PUBLIC_LEGAL_COUNTRY=
PUBLIC_LEGAL_EMAIL=support@vesp-cloud.com
PUBLIC_LEGAL_SUPERVISORY_AUTHORITY=
# Optional; generally not required when you employ ten or fewer people and have not committed to participate
PUBLIC_LEGAL_DISPUTE_RESOLUTION=
