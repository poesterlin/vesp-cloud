{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://esphome-designer.local/schema/components.json",
  "title": "ESPHome Designer Schema",
  "description": "Schema for ESPHome visual display editor components",
  "definitions": {
    "Position": {
      "type": "object",
      "properties": {
        "x": { "type": "number" },
        "y": { "type": "number" }
      },
      "required": ["x", "y"],
      "additionalProperties": false
    },
    "Size": {
      "type": "object",
      "properties": {
        "width": { "type": "number" },
        "height": { "type": "number" }
      },
      "required": ["width", "height"],
      "additionalProperties": false
    },
    "Color": {
      "type": "object",
      "properties": {
        "r": { "type": "integer", "minimum": 0, "maximum": 255 },
        "g": { "type": "integer", "minimum": 0, "maximum": 255 },
        "b": { "type": "integer", "minimum": 0, "maximum": 255 }
      },
      "required": ["r", "g", "b"],
      "additionalProperties": false
    },
    "EntityBinding": {
      "type": "object",
      "properties": {
        "entityId": { "type": "string", "pattern": "^[a-z_]+\\.[a-z_0-9]+$" },
        "attribute": { "type": ["string", "null"] }
      },
      "required": ["entityId"],
      "additionalProperties": false
    },
    "ServiceTarget": {
      "type": "object",
      "properties": {
        "entityId": { "type": "string", "pattern": "^[a-z_]+\\.[a-z0-9_]+$" },
        "deviceId": { "type": "string" }
      },
      "additionalProperties": false
    },
    "ServiceAction": {
      "type": "object",
      "properties": {
        "type": { "const": "SERVICE_CALL" },
        "service": { "type": "string", "pattern": "^[a-z_]+\\.[a-z_0-9]+$" },
        "target": { "$ref": "#/definitions/ServiceTarget" }
      },
      "required": ["type", "service"],
      "additionalProperties": false
    },
    "NavigationAction": {
      "type": "object",
      "properties": {
        "type": { "enum": ["OPEN_DETAIL", "GO_BACK", "NEXT_PAGE", "PREV_PAGE"] },
        "targetId": {
          "type": "string",
          "pattern": "^[A-Z_]+$",
          "description": "Detail view ID (without VIEW_DETAIL_ prefix). Required for OPEN_DETAIL."
        }
      },
      "required": ["type"],
      "additionalProperties": false
    },
    "ActionBinding": {
      "oneOf": [
        { "$ref": "#/definitions/ServiceAction" },
        { "$ref": "#/definitions/NavigationAction" }
      ]
    },
    "ComparisonOperator": {
      "type": "string",
      "enum": ["eq", "neq", "gt", "gte", "lt", "lte", "contains", "not_contains", "matches"]
    },
    "LogicalOperator": {
      "type": "string",
      "enum": ["and", "or"]
    },
    "EntityCondition": {
      "type": "object",
      "description": "Condition based on a Home Assistant entity state",
      "properties": {
        "type": { "const": "entity" },
        "entityId": { "type": "string" },
        "attribute": {
          "type": ["string", "null"],
          "description": "Optional attribute to check instead of state"
        },
        "operator": { "$ref": "#/definitions/ComparisonOperator" },
        "value": {
          "oneOf": [
            { "type": "string" },
            { "type": "number" },
            { "type": "boolean" }
          ]
        }
      },
      "required": ["type", "entityId", "operator", "value"],
      "additionalProperties": false
    },
    "StateCondition": {
      "type": "object",
      "description": "Condition based on internal state variable",
      "properties": {
        "type": { "const": "state" },
        "variable": { "type": "string" },
        "operator": { "$ref": "#/definitions/ComparisonOperator" },
        "value": {
          "oneOf": [
            { "type": "string" },
            { "type": "number" },
            { "type": "boolean" }
          ]
        }
      },
      "required": ["type", "variable", "operator", "value"],
      "additionalProperties": false
    },
    "TimeCondition": {
      "type": "object",
      "description": "Condition based on time of day",
      "properties": {
        "type": { "const": "time" },
        "after": {
          "type": "string",
          "pattern": "^([01]?[0-9]|2[0-3]):[0-5][0-9]$",
          "description": "HH:MM format"
        },
        "before": {
          "type": "string",
          "pattern": "^([01]?[0-9]|2[0-3]):[0-5][0-9]$"
        }
      },
      "required": ["type"],
      "additionalProperties": false
    },
    "CompoundCondition": {
      "type": "object",
      "description": "Combines multiple conditions with AND/OR",
      "properties": {
        "type": { "const": "compound" },
        "operator": { "$ref": "#/definitions/LogicalOperator" },
        "conditions": {
          "type": "array",
          "items": { "$ref": "#/definitions/Condition" }
        }
      },
      "required": ["type", "operator", "conditions"],
      "additionalProperties": false
    },
    "NotCondition": {
      "type": "object",
      "description": "Negates a condition",
      "properties": {
        "type": { "const": "not" },
        "condition": { "$ref": "#/definitions/Condition" }
      },
      "required": ["type", "condition"],
      "additionalProperties": false
    },
    "Condition": {
      "oneOf": [
        { "$ref": "#/definitions/EntityCondition" },
        { "$ref": "#/definitions/StateCondition" },
        { "$ref": "#/definitions/TimeCondition" },
        { "$ref": "#/definitions/CompoundCondition" },
        { "$ref": "#/definitions/NotCondition" }
      ]
    },
    "ConditionalVariant": {
      "type": "object",
      "description": "A single variant/state within a conditional area",
      "properties": {
        "id": { "type": "string" },
        "name": {
          "type": "string",
          "description": "Human-readable name for the editor UI"
        },
        "condition": {
          "$ref": "#/definitions/Condition",
          "description": "When null/undefined, this is the default/fallback variant"
        },
        "priority": {
          "type": "integer",
          "default": 0,
          "description": "Higher priority variants are evaluated first"
        },
        "components": {
          "type": "array",
          "items": { "$ref": "#/definitions/Component" },
          "description": "Components rendered when this variant is active"
        },
        "transition": {
          "type": "object",
          "properties": {
            "type": { "enum": ["none", "fade", "slide"] },
            "duration": { "type": "integer", "description": "milliseconds" }
          }
        }
      },
      "required": ["id", "name", "components"],
      "additionalProperties": false
    },
    "ConditionalAreaComponent": {
      "allOf": [
        { "$ref": "#/definitions/BaseComponent" },
        {
          "type": "object",
          "properties": {
            "type": { "const": "conditional_area" },
            "variants": {
              "type": "array",
              "items": { "$ref": "#/definitions/ConditionalVariant" }
            },
            "defaultVariantId": {
              "type": "string",
              "description": "ID of variant to show when no conditions match"
            },
            "evaluationMode": {
              "type": "string",
              "enum": ["first_match", "priority"],
              "default": "first_match",
              "description": "How to select variant when multiple conditions are true"
            },
            "clipContent": {
              "type": "boolean",
              "default": true,
              "description": "Whether to clip child components to area bounds"
            }
          },
          "required": ["type", "variants"]
        }
      ]
    },
    "TabItem": {
      "type": "object",
      "description": "A single tab inside a tab container",
      "properties": {
        "id": { "type": "string" },
        "name": {
          "type": "string",
          "description": "Tab label shown in the editor"
        },
        "components": {
          "type": "array",
          "items": { "$ref": "#/definitions/Component" },
          "description": "Components rendered when this tab is active"
        }
      },
      "required": ["id", "name", "components"],
      "additionalProperties": false
    },
    "TabContainerComponent": {
      "allOf": [
        { "$ref": "#/definitions/BaseComponent" },
        {
          "type": "object",
          "properties": {
            "type": { "const": "tab_container" },
            "tabs": {
              "type": "array",
              "items": { "$ref": "#/definitions/TabItem" }
            },
            "defaultTabId": {
              "type": "string",
              "description": "ID of tab shown when first rendered"
            },
            "clipContent": {
              "type": "boolean",
              "default": true,
              "description": "Whether to clip child components to tab content bounds"
            }
          },
          "required": ["type", "tabs"]
        }
      ]
    },
    "AutoLayoutDirection": {
      "type": "string",
      "enum": ["horizontal", "vertical"]
    },
    "AutoLayoutAlign": {
      "type": "string",
      "enum": ["start", "center", "end", "stretch"]
    },
    "AutoLayoutJustify": {
      "type": "string",
      "enum": ["start", "center", "end", "space_between"]
    },
    "AutoLayoutListItem": {
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "condition": { "$ref": "#/definitions/Condition" },
        "icon": { "type": "string" },
        "color": { "$ref": "#/definitions/Color" },
        "scale": { "type": "number", "default": 1 }
      },
      "required": ["id", "name"],
      "additionalProperties": false
    },
    "AutoLayoutListComponent": {
      "allOf": [
        { "$ref": "#/definitions/BaseComponent" },
        {
          "type": "object",
          "properties": {
            "type": { "const": "auto_layout_list" },
            "direction": {
              "$ref": "#/definitions/AutoLayoutDirection",
              "default": "horizontal"
            },
            "gap": {
              "type": "number",
              "minimum": 0,
              "default": 6
            },
            "padding": {
              "type": "number",
              "minimum": 0,
              "default": 0
            },
            "crossAxisAlign": {
              "$ref": "#/definitions/AutoLayoutAlign",
              "default": "center"
            },
            "mainAxisJustify": {
              "$ref": "#/definitions/AutoLayoutJustify",
              "default": "start"
            },
            "itemSizeMode": {
              "type": "string",
              "enum": ["content", "fixed"],
              "default": "content"
            },
            "itemWidth": { "type": "number", "minimum": 1 },
            "itemHeight": { "type": "number", "minimum": 1 },
            "items": {
              "type": "array",
              "items": { "$ref": "#/definitions/AutoLayoutListItem" },
              "minItems": 1
            }
          },
          "required": ["type", "size", "items"]
        }
      ]
    },
    "OnTapAction": {
      "oneOf": [
        { "$ref": "#/definitions/ServiceAction" },
        { "$ref": "#/definitions/NavigationAction" }
      ]
    },
    "BaseComponent": {
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string" },
        "position": { "$ref": "#/definitions/Position" },
        "size": { "$ref": "#/definitions/Size" },
        "visible": { "type": "boolean", "default": true },
        "visibleWhen": { "$ref": "#/definitions/EntityBinding" },
        "loadingBinding": { "$ref": "#/definitions/EntityBinding" },
        "onTap": { "$ref": "#/definitions/OnTapAction" },
        "onHold": { "$ref": "#/definitions/OnTapAction" },
        "onDragStart": { "$ref": "#/definitions/OnTapAction" },
        "onDragEnd": { "$ref": "#/definitions/OnTapAction" },
        "variant": { "enum": ["default", "retro", "minimal"], "default": "retro" },
        "borderRadius": { "type": "integer", "description": "Corner radius in pixels" },
        "padding": { "type": "integer", "description": "Padding in pixels (all sides)" },
        "opacity": { "type": "number", "minimum": 0, "maximum": 1, "default": 1, "description": "Widget opacity (0-1)" }
      },
      "required": ["id", "type", "position"]
    },
    "TextComponent": {
      "allOf": [
        { "$ref": "#/definitions/BaseComponent" },
        {
          "type": "object",
          "properties": {
            "type": { "const": "text" },
            "text": {
              "type": "string",
              "description": "Label text. May contain `{{entity.id}}` or `{{entity.id.attribute}}` placeholders that are resolved at runtime; the referenced bindings are derived from this string."
            },
            "textBinding": {
              "$ref": "#/definitions/EntityBinding",
              "description": "Legacy single-binding field. Prefer embedding `{{...}}` placeholders in `text`. Kept for backward compat with older projects."
            },
            "fontSize": { "enum": ["small", "medium", "large"], "default": "medium" },
            "color": { "$ref": "#/definitions/Color" },
            "align": { "enum": ["left", "center", "right"], "default": "left" }
          },
          "required": ["type"]
        }
      ]
    },
    "ButtonComponent": {
      "allOf": [
        { "$ref": "#/definitions/BaseComponent" },
        {
          "type": "object",
          "properties": {
            "type": { "const": "button" },
            "label": { "type": "string" },
            "icon": { "type": "string" },
            "backgroundColor": { "$ref": "#/definitions/Color" },
            "foregroundColor": { "$ref": "#/definitions/Color" },
            "borderColor": { "$ref": "#/definitions/Color" },
            "checkedBackgroundColor": { 
              "$ref": "#/definitions/Color",
              "description": "Background color when button is in checked/active state (for toggle buttons)"
            },
            "checkedForegroundColor": { 
              "$ref": "#/definitions/Color",
              "description": "Text/icon color when button is in checked/active state"
            },
            "pressAction": { "$ref": "#/definitions/ActionBinding" },
            "holdAction": { "$ref": "#/definitions/ActionBinding" }
          },
          "required": ["type", "size"]
        }
      ]
    },
    "SliderComponent": {
      "allOf": [
        { "$ref": "#/definitions/BaseComponent" },
        {
          "type": "object",
          "properties": {
            "type": { "const": "slider" },
            "min": { "type": "number", "default": 0 },
            "max": { "type": "number", "default": 100 },
            "step": { "type": "number", "default": 1 },
            "valueBinding": { "$ref": "#/definitions/EntityBinding" },
            "onChange": { "$ref": "#/definitions/ActionBinding" },
            "orientation": { "enum": ["horizontal", "vertical"], "default": "horizontal" },
            "trackColor": { "$ref": "#/definitions/Color" },
            "fillColor": { "$ref": "#/definitions/Color" },
            "handleColor": { "$ref": "#/definitions/Color" }
          },
          "required": ["type", "size"]
        }
      ]
    },
    "GaugeComponent": {
      "allOf": [
        { "$ref": "#/definitions/BaseComponent" },
        {
          "type": "object",
          "properties": {
            "type": { "const": "gauge" },
            "min": { "type": "number" },
            "max": { "type": "number" },
            "valueBinding": { "$ref": "#/definitions/EntityBinding" },
            "unit": { "type": "string" },
            "backgroundColor": { "$ref": "#/definitions/Color" },
            "needleColor": { "$ref": "#/definitions/Color" },
            "valueColor": { "$ref": "#/definitions/Color" },
            "segments": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "from": { "type": "number" },
                  "to": { "type": "number" },
                  "color": { "$ref": "#/definitions/Color" }
                },
                "required": ["from", "to", "color"],
                "additionalProperties": false
              }
            }
          },
          "required": ["type", "size", "min", "max"]
        }
      ]
    },
    "IconComponent": {
      "allOf": [
        { "$ref": "#/definitions/BaseComponent" },
        {
          "type": "object",
          "properties": {
            "type": { "const": "icon" },
            "icon": { "type": "string" },
            "color": { "$ref": "#/definitions/Color" },
            "scale": { "type": "number", "default": 1 }
          },
          "required": ["type", "size", "icon"]
        }
      ]
    },
    "ProceduralIconComponent": {
      "allOf": [
        { "$ref": "#/definitions/BaseComponent" },
        {
          "type": "object",
          "properties": {
            "type": { "const": "procedural_icon" },
            "iconType": { "enum": ["bulb", "window", "vacuum", "climate"] },
            "stateBinding": { "$ref": "#/definitions/EntityBinding" },
            "color": { "$ref": "#/definitions/Color" }
          },
          "required": ["type", "size", "iconType"]
        }
      ]
    },
    "ContainerComponent": {
      "allOf": [
        { "$ref": "#/definitions/BaseComponent" },
        {
          "type": "object",
          "properties": {
            "type": { "const": "container" },
            "label": { "type": "string" },
            "backgroundColor": { "$ref": "#/definitions/Color" },
            "children": {
              "type": "array",
              "items": { "$ref": "#/definitions/Component" },
              "description": "Child components rendered inside this container"
            }
          },
          "required": ["type", "size"]
        }
      ]
    },
    "ImageComponent": {
      "allOf": [
        { "$ref": "#/definitions/BaseComponent" },
        {
          "type": "object",
          "properties": {
            "type": { "const": "image" },
            "imageSource": {
              "enum": ["static", "ha"],
              "default": "static",
              "description": "Whether the image comes from a static ESPHome image entry or a Home Assistant image/camera entity."
            },
            "file": { "type": "string" },
            "imageBinding": {
              "$ref": "#/definitions/EntityBinding",
              "description": "Home Assistant image/camera entity. The entity_picture attribute is used by default and loaded with online_image."
            },
            "onlineFormat": {
              "enum": ["png", "jpeg"],
              "default": "png",
              "description": "Encoded format expected from the online image URL when imageBinding is used."
            },
            "image_type": { "enum": ["BINARY", "GRAYSCALE", "RGB565", "RGB"], "description": "Specifies how to encode image internally." },
            "resize": { "type": "string", "pattern": "^\\d+x\\d+$" },
            "transparency": { "enum": ["opaque", "chroma_key", "alpha_channel"] },
            "invert_alpha": { "type": "boolean", "default": false },
            "dither": { "enum": ["NONE", "FLOYDSTEINBERG"] },
            "byte_order": { "enum": ["big_endian", "little_endian"] },
            "foregroundColor": { "$ref": "#/definitions/Color" },
            "backgroundColor": { "$ref": "#/definitions/Color" }
          },
          "required": ["type", "file", "image_type", "size"]
        }
      ]
    },
    "TodoListComponent": {
      "allOf": [
        { "$ref": "#/definitions/BaseComponent" },
        {
          "type": "object",
          "properties": {
            "type": { "const": "todo_list" },
            "itemsBinding": { "$ref": "#/definitions/EntityBinding" },
            "todoEntityId": {
              "type": "string",
              "pattern": "^[a-z_]+\\.[a-z0-9_]+$",
              "description": "Home Assistant todo entity used for check-off actions"
            },
            "maxItems": {
              "type": "integer",
              "minimum": 1,
              "maximum": 10,
              "default": 4
            },
            "rowHeight": {
              "type": "integer",
              "minimum": 20,
              "maximum": 80,
              "default": 30
            },
            "scrollable": {
              "type": "boolean",
              "default": false
            },
            "checkable": {
              "type": "boolean",
              "default": false
            }
          },
          "required": ["type", "size"]
        }
      ]
    },
    "LightStateComponent": {
      "allOf": [
        { "$ref": "#/definitions/BaseComponent" },
        {
          "type": "object",
          "properties": {
            "type": { "const": "light_state" },
            "label": { "type": "string" },
            "stateBinding": { "$ref": "#/definitions/EntityBinding" },
            "targetDevice": {
              "type": "object",
              "properties": {
                "deviceId": { "type": "string" },
                "deviceName": { "type": "string" }
              },
              "required": ["deviceId"],
              "additionalProperties": false
            },
            "showBrightnessControl": { "type": "boolean", "default": false },
            "onText": { "type": "string", "default": "ON" },
            "offText": { "type": "string", "default": "OFF" },
            "showIcon": { "type": "boolean", "default": true },
            "icon": { "type": "string", "default": "lightbulb" },
            "onColor": { "$ref": "#/definitions/Color" },
            "offColor": { "$ref": "#/definitions/Color" }
          },
          "required": ["type", "size"]
        }
      ]
    },
    "Component": {
      "oneOf": [
        { "$ref": "#/definitions/TextComponent" },
        { "$ref": "#/definitions/ButtonComponent" },
        { "$ref": "#/definitions/SliderComponent" },
        { "$ref": "#/definitions/GaugeComponent" },
        { "$ref": "#/definitions/IconComponent" },
        { "$ref": "#/definitions/ProceduralIconComponent" },
        { "$ref": "#/definitions/ContainerComponent" },
        { "$ref": "#/definitions/ImageComponent" },
        { "$ref": "#/definitions/TodoListComponent" },
        { "$ref": "#/definitions/LightStateComponent" },
        { "$ref": "#/definitions/AutoLayoutListComponent" },
        { "$ref": "#/definitions/ConditionalAreaComponent" },
        { "$ref": "#/definitions/TabContainerComponent" }
      ]
    },
    "Page": {
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "backgroundColor": { "$ref": "#/definitions/Color" },
        "components": {
          "type": "array",
          "items": { "$ref": "#/definitions/Component" }
        }
      },
      "required": ["id", "name", "components"],
      "additionalProperties": false
    },
    "DetailView": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[A-Z_]+$",
          "description": "Short view name in UPPER_SNAKE_CASE (e.g., TEMPS, VACUUM). Generator prepends VIEW_DETAIL_ prefix for enum."
        },
        "title": { "type": "string" },
        "height": {
          "type": "number",
          "description": "Total virtual height in pixels; maxScrollY = height - headerHeight"
        },
        "headerHeight": {
          "type": "number",
          "default": 45,
          "description": "Height of the detail view header (default: 45px)"
        },
        "components": {
          "type": "array",
          "items": { "$ref": "#/definitions/Component" }
        }
      },
      "required": ["id", "title", "height", "components"],
      "additionalProperties": false
    },
    "StateField": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z_]+$",
          "description": "Variable name in gState (e.g., outsideTemp)"
        },
        "cppType": {
          "type": "string",
          "enum": ["float", "int", "bool", "std::string"],
          "description": "C++ type"
        },
        "haEntity": {
          "type": "string",
          "pattern": "^[a-z_]+\\.[a-z_0-9]+$",
          "description": "Home Assistant entity (sensor.outside_temp)"
        },
        "defaultValue": {
          "type": ["string", "number", "boolean"],
          "description": "Initial value (e.g., 0, false, '')"
        }
      },
      "required": ["name", "cppType", "haEntity"],
      "additionalProperties": false
    },
    "StateConfig": {
      "type": "object",
      "properties": {
        "fields": {
          "type": "array",
          "items": { "$ref": "#/definitions/StateField" },
          "description": "Sensor fields to include in DisplayState"
        }
      },
      "additionalProperties": false
    },
    "Theme": {
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "colors": {
          "type": "object",
          "properties": {
            "background": { "$ref": "#/definitions/Color" },
            "backgroundSecondary": { "$ref": "#/definitions/Color" },
            "foreground": { "$ref": "#/definitions/Color" },
            "foregroundMuted": { "$ref": "#/definitions/Color" },
            "accent": { "$ref": "#/definitions/Color" },
            "accentSecondary": { "$ref": "#/definitions/Color" },
            "success": { "$ref": "#/definitions/Color" },
            "warning": { "$ref": "#/definitions/Color" },
            "error": { "$ref": "#/definitions/Color" }
          },
          "required": ["background", "foreground", "accent"]
        },
        "style": {
          "type": "object",
          "properties": {
            "buttonShadow": { "type": "boolean" },
            "buttonCornerAccents": { "type": "boolean" },
            "containerCorners": { "type": "boolean" },
            "headerBorders": { "type": "boolean" }
          }
        },
        "values": {
          "type": "object",
          "properties": {
            "shadowOffset": { "type": "number" },
            "cornerSize": { "type": "number" },
            "borderRadius": { "type": "number" }
          }
        }
      },
      "required": ["id", "name", "colors"]
    },
    "FontDefinition": {
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "file": { "type": "string" },
        "size": { "type": "integer" }
      },
      "required": ["id", "file", "size"],
      "additionalProperties": false
    },
    "SecretsConfig": {
      "type": "object",
      "description": "OTA update configuration",
      "properties": {
        "firmwareUpdateUrl": {
          "type": "string",
          "description": "Firmware update URL for OTA via HTTP (auto-populated from server)"
        },
        "homeAssistantBaseUrl": {
          "type": "string",
          "description": "Optional base URL used to resolve relative Home Assistant entity_picture URLs"
        }
      },
      "additionalProperties": false
    },
    "PageHeader": {
      "type": "object",
      "description": "Project-level page header shown on all dashboard pages",
      "properties": {
        "height": {
          "type": "number",
          "description": "Height of the header region in pixels"
        },
        "backgroundColor": {
          "$ref": "#/definitions/Color",
          "description": "Background color of the header region (falls back to theme background)"
        },
        "components": {
          "type": "array",
          "items": { "$ref": "#/definitions/Component" },
          "description": "Components rendered in the header region (positions relative to header origin)"
        }
      },
      "required": ["height", "components"],
      "additionalProperties": false
    },
    "NotificationOverlayConfig": {
      "type": "object",
      "description": "Global high-priority Home Assistant notification overlay settings",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": true
        },
        "titleEntityId": {
          "type": "string",
          "pattern": "^[a-z_]+\\.[a-z0-9_]+$"
        },
        "bodyEntityId": {
          "type": "string",
          "pattern": "^[a-z_]+\\.[a-z0-9_]+$"
        },
        "severityEntityId": {
          "type": "string",
          "pattern": "^[a-z_]+\\.[a-z0-9_]+$"
        }
      },
      "additionalProperties": false
    },
    "DisplayConfig": {
      "type": "object",
      "properties": {
        "width": { "type": "integer", "default": 480 },
        "height": { "type": "integer", "default": 480 }
      },
      "required": ["width", "height"],
      "additionalProperties": false
    },
    "Project": {
      "type": "object",
      "properties": {
        "version": { 
          "type": "string", 
          "description": "Schema version. ALWAYS increment this if there are breaking changes to the JSON structure.",
          "default": "1.0.1"
        },
        "id": { "type": "string" },
        "name": { "type": "string" },
        "theme": { "$ref": "#/definitions/Theme" },
        "display": { "$ref": "#/definitions/DisplayConfig" },
        "state": { "$ref": "#/definitions/StateConfig" },
        "dashboardPages": {
          "type": "array",
          "items": { "$ref": "#/definitions/Page" }
        },
        "detailViews": {
          "type": "array",
          "items": { "$ref": "#/definitions/DetailView" }
        },
        "fonts": {
          "type": "array",
          "items": { "$ref": "#/definitions/FontDefinition" }
        },
        "secrets": { "$ref": "#/definitions/SecretsConfig" },
        "pageHeader": { "$ref": "#/definitions/PageHeader" },
        "notificationOverlay": { "$ref": "#/definitions/NotificationOverlayConfig" },
        "timezone": {
          "type": "string",
          "description": "IANA timezone identifier (e.g. America/New_York, Europe/Berlin)"
        }
      },
      "required": ["name", "display", "dashboardPages", "detailViews"],
      "additionalProperties": false
    }
  }
}
