{
  "name": "@vesp-cloud/schema",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/types.ts",
  "types": "./dist/types.ts",
  "exports": {
    ".": {
      "types": "./dist/types.ts",
      "import": "./dist/types.ts"
    },
    "./condition-builder": {
      "import": "./condition-builder.ts"
    },
    "./schema": {
      "import": "./components.json",
      "require": "./components.json"
    },
    "./homeassistant": {
      "types": "./homeassistant-dump.ts",
      "import": "./homeassistant-dump.ts"
    }
  },
  "scripts": {
    "generate": "bun run generate-types.ts",
    "test": "bun test",
    "lint": "tsc --noEmit"
  },
  "devDependencies": {
    "json-schema-to-typescript": "^15.0.0",
    "typescript": "^5.7.0"
  }
}
